let LIMIT: int = 100000

let mut sieve: []bool = []
let mut i: int = 0
for i <= LIMIT do
    append(sieve, true)
    i += 1
end

sieve[0] = false
sieve[1] = false

let mut p: int = 2
for p * p <= LIMIT do
    if sieve[p] then
        let mut m: int = p * p
        for m <= LIMIT do
            sieve[m] = false
            m += p
        end
    end
    p += 1
end

let mut count: int = 0
let mut k: int = 2
for k <= LIMIT do
    if sieve[k] then
        count += 1
    end
    k += 1
end

echo(count)

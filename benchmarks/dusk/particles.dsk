let Particle = struct
    x: float
    y: float
    vx: float
    vy: float

let mut particles: []Particle = []

let mut i: int = 0
for i < 100000
    let fx: float = i * 1.0
    append(particles, @(x = fx, y = i * 2.0, vx = 0.5, vy = -0.5))
    i += 1

let mut step: int = 0
for step < 100
    let mut j: int = 0
    for j < 100000
        particles[j].x = particles[j].x + particles[j].vx
        particles[j].y = particles[j].y + particles[j].vy
        j += 1
    step += 1

echo(particles[49999].x)

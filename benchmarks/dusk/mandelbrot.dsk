let W: int = 800
let H: int = 800
let MAX_ITER: int = 1000

let mut sum: int = 0
let mut py: int = 0
for py < H
    let cy: float = -1.0 + (py / H) * 2.0
    let mut px: int = 0
    for px < W
        let cx: float = -2.5 + (px / W) * 3.5

        let mut zx: float = 0.0
        let mut zy: float = 0.0
        let mut zx2: float = 0.0
        let mut zy2: float = 0.0
        let mut iter: int = 0

        for zx2 + zy2 <= 4.0 and iter < MAX_ITER
            zy = 2.0 * zx * zy + cy
            zx = zx2 - zy2 + cx
            zx2 = zx * zx
            zy2 = zy * zy
            iter += 1

        sum += iter
        px += 1
    py += 1

echo(sum)

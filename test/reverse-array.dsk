let reverse_list: fn = (mut arr: []string) -> []string
    let n: number = len(arr)
    let mut result: []string = []
    let mut i: number = n - 1

    for i > -1
        let val: string = arr[i]
        append(result, val)
        i = i - 1

    return result

let mut arr: []string = ["Salve", "General", "Doutor", "Hoje", "Eu", "Não"]
let reversed: []string = reverse_list(arr)
echo(reversed)



assert(1 + 2 == 3)
assert(5 - 3 == 2)
assert(3 * 4 == 12)
assert(10 // 3 == 3)
assert(10 % 3 == 1)

assert(1.0 + 2 == 3.0)
assert(1 + 2.0 == 3.0)
assert(1.0 + 2.0 == 3.0)
assert(5.0 - 2 == 3.0)
assert(3.0 * 2 == 6.0)
assert(5.0 % 2 == 1.0)

assert(1 == 1)
assert(1 != 2)
assert(1 < 2)
assert(2 > 1)
assert(1 <= 1)
assert(2 >= 1)

assert(1.0 == 1.0)
assert(1.0 != 2.0)
assert(1.0 == 1)
assert(1 == 1.0)
assert(3.14 != 2)
assert(2 != 3.14)
assert(1.0 < 2.0)
assert(1.0 < 2)
assert(1 < 2.0)
assert(2.0 > 1.0)
assert(2.0 > 1)
assert(2 > 1.0)
assert(1.0 <= 1.0)
assert(1.0 <= 1)
assert(2.0 >= 1)
assert(1 >= 1.0)

assert(true == true)
assert(true != false)
assert(false == false)
assert(false != true)

assert(true and true)
assert(false or true)
assert(!false)

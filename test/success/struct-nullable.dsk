let Country = struct
    id: int
    name: string
    code: ?string
end

let Address = struct
    city: ?string
    state: ?string
    country: ?Country
    street: ?string
end

let UserInfo = struct
    address: ?Address
    phone: ?string
end

let User = struct
    info: ?UserInfo
end

let mut user = User(
    info = @(
        address = @(
            city = null,
            state = "DF",
            country = @(
                id = 1,
                name = "Brasil",
                code = "BR"
            )
        ),
        phone = null
    ),
)


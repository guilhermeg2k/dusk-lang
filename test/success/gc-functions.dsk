let make_array: fn = (n: int) -> []int
    let mut result: []int = []
    let mut i = 0
    for i < n
        append(result, i)
        i += 1
    return result

let mut i = 0
for i < 10000
    let trash = make_array(10)
    i += 1

let kept = make_array(5)
assert(len(kept) == 5)
assert(kept[0] == 0)
assert(kept[4] == 4)

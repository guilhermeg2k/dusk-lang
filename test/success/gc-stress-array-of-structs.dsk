# GC stress: array of structs survives many collection cycles
# tests GC tracing through array elements that are heap-typed (structs)
let canary = [@(x = 1, y = 2), @(x = 3, y = 4), @(x = 5, y = 6)]

let mut i: int = 0
for i < 50000 do
    let trash = [@(x = i, y = i + 1), @(x = i + 2, y = i + 3)]
    i += 1
end

assert(len(canary) == 3)
assert(canary[0].x == 1)
assert(canary[0].y == 2)
assert(canary[1].x == 3)
assert(canary[1].y == 4)
assert(canary[2].x == 5)
assert(canary[2].y == 6)


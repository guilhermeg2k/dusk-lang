let x1 = 1 + 2 * 3
let x2 = (1 + 2) * 3
let x3 = 10 + 5 % 2
let x4 = (10 + 5) % 2
let x5 = 10 - 2 - 3
let x6 = 10 - (2 - 3)
let x7 = -5 + 3
let x8 = -(5 + 3)
let x9 = -5
let x10 = true or false and false
let x11 = true or false and true
let x12 = !true and true
let x13 = 5 > 2 + 5
let x14 = 2 * (3 + 4 * 5)
let x15 = ((1 + 1) * (2 + 2))

let o = 3.5//2

assert(x1 == 7)
assert(x2 == 9)
assert(x3 == 11)
assert(x4 == 1)
assert(x5 == 5)
assert(x6 == 11)

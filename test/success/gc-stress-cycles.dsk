# stress GC with 500k iterations creating arrays and structs
# keeps two canaries alive to verify data survives many collection cycles
let array_canary = [42, 99, 1337]
let struct_canary = @(x = 77, y = 88, flag = true)

let mut i = 0
for i < 500000 do
    let trash_arr = [i, i + 1, i + 2, i + 3, i + 4]
    let trash_s = @(a = i, b = i * 2, c = i * 3)
    i += 1
end

assert(array_canary[0] == 42)
assert(array_canary[1] == 99)
assert(array_canary[2] == 1337)
assert(struct_canary.x == 77)
assert(struct_canary.y == 88)
assert(struct_canary.flag == true)
assert(i == 500000)

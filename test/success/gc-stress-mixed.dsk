# stress GC with all heap types: strings, arrays, and nested structs
# keeps one canary of each type, verifies all survive 500k iterations
let array_canary = [10, 20, 30]
let nested_canary = @(data = [1, 2, 3], count = 42)

let mut i = 0
for i < 500000 do
    let trash_string = "hello"
    let trash_array = [i, i + 1]
    let trash_nested = @(items = [i, i, i], n = i)
    i += 1
end

assert(array_canary[0] == 10)
assert(array_canary[1] == 20)
assert(array_canary[2] == 30)
assert(nested_canary.count == 42)
assert(nested_canary.data[0] == 1)
assert(nested_canary.data[2] == 3)
assert(i == 500000)

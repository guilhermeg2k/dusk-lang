# GC stress: struct field mutation under GC + trash structs with array fields
# tests that freshly allocated structs survive GC during field initialization
let canary = @(id = 999, extra = [99, 99, 99])

let mut i: int = 0
for i < 50000 do
    canary.extra = [i, i, i]
    let trash = @(value = i, items = [i, i + 1, i + 2, i + 3])
    i += 1
end

assert(canary.id == 999)
assert(canary.extra[0] == 49999)
assert(canary.extra[1] == 49999)
assert(canary.extra[2] == 49999)


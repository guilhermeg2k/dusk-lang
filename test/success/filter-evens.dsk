let filter_evens: fn = (arr: []int) -> []int
    let mut result : []int = []
    let n: int = len(arr)
    let mut i: int = 0

    for i < n
        let val: int = arr[i]
        if val % 2 == 0
            append(result, val)
        i = i + 1

    return result

let arr: []int = [1,3,5,1,10,33,34,33,100,20,10,40]
let evens: []int = filter_evens(arr)
echo(evens)


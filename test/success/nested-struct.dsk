struct User
    id: string
    username: string
    auth_provider: string

    address: struct
        country: string
        state: string
        city: string
        street: string
    end

    default_address = @(
        country = "Brasil",
        state = "SP",
        city = "São Paulo",
        street = "Av. Paulista"
    )
end

let user = User(
    id="1",
    username="Rogerinho",
    auth_provider="G",
    address = @(
        country = "Brasil",
        state = "DF",
        city = "Brasília",
        street = "Eixão Sul"
    )
)

echo(user)


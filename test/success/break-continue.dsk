let test_break = () -> int
    let mut i: int = 0
    for i < 10
        if i == 4
            break
        i = i + 1
    return i

assert(test_break() == 4)

let test_continue = () -> int
    let mut i: int = 0
    let mut sum: int = 0
    for i < 10
        i = i + 1
        if i % 2 == 0
            continue
        sum = sum + i
    return sum

assert(test_continue() == 25)

let test_break_if = () -> int
    let mut i: int = 0
    for i < 100
        if i > 10
            break
        i = i + 1
    return i

assert(test_break_if() == 11)

let test_continue_if = () -> int
    let mut i: int = 0
    let mut sum: int = 0
    for i < 10
        if i < 5
            i = i + 1
            continue
        sum = sum + i
        i = i + 1
    return sum

assert(test_continue_if() == 35)

let test_nested_break = () -> int
    let mut i: int = 0
    let mut acc: int = 0
    for i < 5
        let mut j: int = 0
        for j < 10
            if j == 3
                break
            j = j + 1
        acc = acc + j
        i = i + 1
    return acc

assert(test_nested_break() == 15)

let test_nested_continue = () -> int
    let mut i: int = 0
    let mut acc: int = 0
    for i < 3
        let mut j: int = 0
        for j < 4
            j = j + 1
            if j == 2
                continue
            acc = acc + 1
        i = i + 1
    return acc

assert(test_nested_continue() == 9)

let test_if_else_fallthrough = (a: int) -> int
    if a < 10
        return a
    return a * 2

assert(test_if_else_fallthrough(5) == 5)
assert(test_if_else_fallthrough(15) == 30)

let test_infinite_break = () -> int
    let mut i: int = 0
    for true
        if i == 7
            break
        i = i + 1
    return i

assert(test_infinite_break() == 7)

let test_break_nested_if = () -> int
    let mut i: int = 0
    for i < 50
        if i < 3
            i = i + 1
        else
            if i > 7
                break
            i = i + 1
    return i

assert(test_break_nested_if() == 8)

let test_else_if: fn = (a: int) -> int
    if a < 0
        return -1
    else if a == 0
        return 0
    return 1

assert(test_else_if(-5) == -1)
assert(test_else_if(0) == 0)
assert(test_else_if(5) == 1)

let test_break = () -> int
    let mut i: int = 0
    for i < 10 do
        if i == 4 then
            break
        end
        
        i = i + 1
    end
    
    return i
end


assert(test_break() == 4)

let test_continue = () -> int
    let mut i: int = 0
    let mut sum: int = 0
    for i < 10 do
        i = i + 1
        if i % 2 == 0 then
            continue
        end
        
        sum = sum + i
    end
    
    return sum
end


assert(test_continue() == 25)

let test_break_if = () -> int
    let mut i: int = 0
    for i < 100 do
        if i > 10 then
            break
        end
        
        i = i + 1
    end
    
    return i
end


assert(test_break_if() == 11)

let test_continue_if = () -> int
    let mut i: int = 0
    let mut sum: int = 0
    for i < 10 do
        if i < 5 then
            i = i + 1
            continue
        end
        
        sum = sum + i
        i = i + 1
    end
    
    return sum
end


assert(test_continue_if() == 35)

let test_nested_break = () -> int
    let mut i: int = 0
    let mut acc: int = 0
    for i < 5 do
        let mut j: int = 0
        for j < 10 do
            if j == 3 then
                break
            end
            
            j = j + 1
        end
        
        acc = acc + j
        i = i + 1
    end
    
    return acc
end


assert(test_nested_break() == 15)

let test_nested_continue = () -> int
    let mut i: int = 0
    let mut acc: int = 0
    for i < 3 do
        let mut j: int = 0
        for j < 4 do
            j = j + 1
            if j == 2 then
                continue
            end
            
            acc = acc + 1
        end
        
        i = i + 1
    end
    
    return acc
end


assert(test_nested_continue() == 9)

let test_if_else_fallthrough = (a: int) -> int
    if a < 10 then
        return a
    end
    
    return a * 2
end


assert(test_if_else_fallthrough(5) == 5)
assert(test_if_else_fallthrough(15) == 30)

let test_infinite_break = () -> int
    let mut i: int = 0
    for true do
        if i == 7 then
            break
        end
        
        i = i + 1
    end
    
    return i
end


assert(test_infinite_break() == 7)

let test_break_nested_if = () -> int
    let mut i: int = 0
    for i < 50 do
        if i < 3 then
            i = i + 1
        else
            if i > 7 then
                break
            end
            
            i = i + 1
        end
    end
    
    return i
end


assert(test_break_nested_if() == 8)

let test_else_if = (a: int) -> int
    if a < 0 then
        return -1
    else
        if a == 0 then
            return 0
        end
    end
    
    return 1
end


assert(test_else_if(-5) == -1)
assert(test_else_if(0) == 0)
assert(test_else_if(5) == 1)

let canary = @(value = 42, extra = [42, 42, 42])

let mut i = 0
for i < 200000
    let _a = [i, i * 2, i * 3]
    i += 1

let mut j = 0
for j < 200000
    let _b = [j + 1, j + 2, j + 3, j + 4]
    j += 1

if canary.value >= 0
    let mut k = 0
    for k < 1000
        let _c = [k, k, k]
        k += 1

assert(canary.value == 42)
assert(canary.extra[0] == 42)
assert(canary.extra[2] == 42)
assert(i == 200000)
assert(j == 200000)

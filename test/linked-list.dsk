let Node = struct
    left: ?Node
    right: ?Node
    value: number

    add(mut self: @, left: ?Node, right: ?Node) -> void
        self.left = left
        self.right = right

let mut root = Node(value = 100, left = null, right = null)

root.add(
    left = Node(value = 10, left = null, right = null),
    right = Node(value = 90, left = null, right = null)
)

echo(stringify(root))


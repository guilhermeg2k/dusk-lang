let Node = struct
    value: int
    next: ?Node

let LinkedList = struct
    root: ?Node
    tail: ?Node
    len: int = 0

    add: (mut self: @, value: int) -> void
        let new_node = @(value = value, next = null)

        if self.tail: mut tail
            tail.next = new_node
            self.tail = new_node
        else
            self.root = new_node
            self.tail = new_node

        self.len += 1

    add_head: (mut self: @, value: int) -> void
        let new_node = @(value = value, next = self.root)
        self.root = new_node

        if self.tail == null
            self.tail = new_node

        self.len += 1

    pop_value: (mut self: @, value: int) -> bool
        let mut cur_node = self.root
        let mut previous_node: ?Node = null

        for cur_node != null
            if cur_node: mut c_node
                if c_node.value != value
                    previous_node = cur_node
                    cur_node = c_node.next
                    continue

                if previous_node: mut p_node
                    p_node.next = c_node.next
                    if c_node.next == null
                        self.tail = previous_node
                else
                    self.root = c_node.next
                    if self.root == null
                        self.tail = null

                self.len -= 1
                return true

        return false

    pop: (mut self: @) -> void
        if self.root == null
            return

        if self.root == self.tail
            self.root = null
            self.tail = null
        else
            let mut cur_node = self.root
            for cur_node != null
                if cur_node: mut c_node
                    if c_node.next == self.tail
                        c_node.next = null
                        self.tail = cur_node
                        break
                    cur_node = c_node.next

        self.len -= 1

    contains: (self: @, value: int) -> bool
        let mut cur_node = self.root
        for cur_node != null
            if cur_node: c_node
                if c_node.value == value
                    return true
                cur_node = c_node.next
        return false

    print: (self: @) -> void
        let mut cur_node = self.root
        for cur_node != null
            if cur_node: c_node
                echo(c_node.value)
                cur_node = c_node.next

let mut list = LinkedList(root = null, tail = null)

list.add(10)
list.add(20)
list.add(30)
list.add(40)
list.add_head(50)
list.add_head(60)
list.print()
echo(list.contains(10))
echo(list.len)
list.pop()
list.pop()
list.print()
echo(list.len)
list.pop_value(50)
list.pop_value(60)
echo(list.contains(60))
list.print()
echo(list.len)

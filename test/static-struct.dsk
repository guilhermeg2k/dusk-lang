let Api = struct
    #Static fields
    let ip = "127.0.0.1"
    let mut port: string = "8080"

    #Fields
    endpoint: string = ""

    #Methods
    fetch: (self: @) -> string
        let base = concat(Api.ip, Api.port)
        return concat(base, self.endpoint)


let api = Api("/me")

Api.port = ":9090"

echo(api.fetch())
echo(Api.fetch(api))
echo(Api.port)




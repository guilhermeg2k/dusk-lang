let Api = struct
    #Static fields
    let base_url: string = "https://localhost:8080"

    #Fields
    endpoint: string = ""

    #Methods
    fetch: (self: @) -> string
        return concat(Api.base_url, self.endpoint)


let api = Api("/me")

echo(api.fetch())
echo(Api.fetch(api))
echo(Api.base_url)



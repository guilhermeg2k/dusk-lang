let User = struct
    id: number
    auth_id: string
    username: string
    auth_provider: string

    who_iam: (self: @) -> string
        return concat(self.auth_id, self.username)

let user = User(id=1, auth_id="XWQ#@!#@!", username="guig2k", auth_provider="discord")
user.username = "Salve"
echo(user.who_iam())



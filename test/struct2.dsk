let User = struct
    id: number
    auth_id: string
    username: string
    auth_provider: string
    d: D

    who_iam: (self: @) -> string
        return concat(self.auth_id, self.username)


let mut user = User(
    id = 1,
    auth_id = "dadz12x3124z",
    username = "Geromel",
    auth_provider = "discord",
)

user.username = "Ronaldinho 2"
echo(stringify(user))

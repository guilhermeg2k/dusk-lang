let add = (a: number, b: number) -> return a + b

let is_even = (x: number) -> return (x % 2) == 0

let res = 2 |> add(1) |> is_even()

let sub = (a: number, b: number) -> return a - b

let res2 = 2
    |> add(2)
    |> is_even()

let res3 = 2
    |> add(2)
    + 3
    |> sub(1)

assert(res == false)
assert(res2 == true)
assert(res3 == 6)
echo("dusk!")

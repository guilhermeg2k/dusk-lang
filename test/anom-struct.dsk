
let User = struct
    id: string
    auth_id: string
    username: string
    auth_provider: string

    to_string: (self: @) -> string
        return concat(self.id, self.username)

    change_id: (mut self: @, id: string) -> string
        self.id = id

let User2 = struct
    id: string
    auth_id: string
    username: string
    auth_provider: string

    to_string: (self: @) -> string
        return concat(self.username, self.id)

    change_id: (mut self: @, id: string) -> string
        self.id = id

let who_is = (user: User) -> string
    return user.to_string()

let point = @(x = 2, y = 3)

let user: User = @(id="1", auth_id="4", username="Geromel", auth_provider="discord")

let user2: User2 = @(
    id="1",
    auth_id="4",
    username="Geromel",
    auth_provider="discord"
)

let user3 = @(id="1", auth_id=4, username="Geromel", auth_provider="discord")

user.change_id("USER 1 - ")
user2.change_id("USER 2 - ")
echo(who_is(user))
echo(who_is(user2))

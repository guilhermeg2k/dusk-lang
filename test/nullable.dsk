let Node = struct
    left: ?Node
    right: ?Node
    value: number


let node = Node(
    left = null,
    right = null,
    value = 10
)

let node2 = Node(
    left = node,
    right = null,
    value = 30
)

if node2.left != null
    echo(node2.left.value)

if node.right != null
    echo(node.right.value)

echo(node2.value)


